{
    "extends": ["./eslint/eslint-defaults.json", "./eslint/eslint-babel.json"],
    "env": {
        "browser": true,
        "worker": true,
    },
    "overrides": [
        {
            "files": ["*worker*.js", "*Worker*.js"],
            "parserOptions": {
                "sourceType": "script",
            },
        },
    ],
}
